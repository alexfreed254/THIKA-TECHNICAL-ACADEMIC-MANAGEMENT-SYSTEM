# ── Flask ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development

# One-time bootstrap only (then delete / unset). Required for /super-admin/setup-profile
# SETUP_PROFILE_TOKEN=long-random-token

# Required for biometric scanners (POST /biometric/api/scan and /api/enroll)
# BIOMETRIC_DEVICE_SECRET=long-random-device-secret

# ── Supabase ───────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Supabase Storage Buckets ─────────────────────────────────────────────────────
# Prefer PRIVATE buckets + signed URLs in production.
# PRIVATE_STORAGE=true
# - assessment-scripts
# - assessment-evidence

# Allow public trainee self-registration only when explicitly enabled
# ALLOW_STUDENT_SELF_REGISTER=false

# ── SPA (optional) ─────────────────────────────────────────────────────────────
# SPA_CROSS_SITE=false
# SPA_ORIGINS=http://localhost:5173
# SESSION_COOKIE_SECURE=false
